# ============================================
# Repository UN - Backend Configuration
# ============================================
# Salin file ini menjadi .env dan sesuaikan nilai-nilainya
#   copy .env.example .env

# --- Database ---
DATABASE_URL=postgres://postgres:your_password@localhost:5432/repository_db

# --- SMTP Email Configuration ---
# Digunakan untuk mengirim token akses file yang terkunci
#
# Untuk Gmail:
#   1. Aktifkan 2-Step Verification di Google Account
#   2. Buat App Password: https://myaccount.google.com/apppasswords
#   3. Pilih "Mail" dan "Windows Computer" (atau Other)
#   4. Copy 16-digit password yang muncul, gunakan sebagai SMTP_PASSWORD
#
# Untuk Yahoo Mail:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#
# Untuk Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
